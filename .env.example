# Prisma Accelerate URL used by Cloudflare Pages Functions runtime.
DATABASE_URL="prisma://accelerate.prisma-data.net/?api_key=YOUR_ACCELERATE_KEY"

# Direct Postgres URL (Supabase) used for local Prisma CLI/migrations/bootstrap scripts.
DIRECT_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres"

# JWT secret used to sign and verify auth tokens.
JWT_SECRET="replace-with-a-long-random-secret"

# Resend API key used for verification/reset emails.
RESEND_API_KEY="re_xxxxxxxxx"

# Public app URL used to build links inside emails.
DOMAIN="https://your-app-domain.com"

# Optional owner bootstrap settings (used only with npm run bootstrap:owner).
BOOTSTRAP_OWNER_ENABLED="false"
BOOTSTRAP_OWNER_EMAIL="owner@example.com"
BOOTSTRAP_OWNER_PASSWORD="ChangeMe123!"
BOOTSTRAP_OWNER_NAME="Initial Owner"
BOOTSTRAP_WORKSPACE_ID="default-workspace"
BOOTSTRAP_WORKSPACE_SLUG="default"
BOOTSTRAP_WORKSPACE_NAME="Default Workspace"
